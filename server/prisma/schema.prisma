// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id          String   @id @default(cuid())

  firstName   String
  lastName    String

  email       String   @unique
  phone       String   @unique

  gender      String?

  city        String?
  country     String?
  address     String?

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]

  @@map("students")
}


model Course {
  id          String   @id @default(cuid())

  title       String
  description String
  features    String[]

  category    EnrollmentMode @default(ONE_ON_ONE)

  imageUrl    String
  imageId     String

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]
  packages    CoursePackage[]

  @@map("courses")
}

// One row per (course, region, packageTier). Local (Pakistan) pricing is stored as a
// single row with packageTier = NONE since Pakistani students never choose between tiers.
model CoursePackage {
  id          String      @id @default(cuid())

  courseId    String

  region      Region
  currency    String

  packageTier PackageTier @default(NONE)

  title       String?
  description String
  imageUrl    String

  price       Decimal

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  course      Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, region, packageTier])
  @@map("course_packages")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  firstName        String
  lastName         String
  role             Role      @default(USER)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("users")
}

model Enrollment {
  id              String           @id @default(cuid())
  studentId       String
  courseId        String

  preferredHour   Int?
  preferredMinute Int?
  preferredPeriod String?          // e.g. "AM" or "PM"
  preferredDays   String?          // e.g. "Monday, Wednesday, Friday"

  enrollmentType  EnrollmentType   @default(REGULAR)
  packageTier     PackageTier?
  appliedCurrency String?
  appliedPrice    Decimal?

  status          EnrollmentStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payment Payment?

  @@unique([studentId, courseId])
  @@map("enrollments")
}

model Payment {
  id                 String        @id @default(cuid())
  enrollmentId       String        @unique
  amount             Decimal
  paymentMethod      PaymentMethod
  transactionId      String?
  screenshotUrl      String
  screenshotPublicId String
  status             PaymentStatus @default(UNDER_REVIEW)
  adminNote          String?
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  enrollment         Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PaymentSetting {
  id              String   @id @default(cuid())
  bankName        String
  accountTitle    String
  accountNumber   String
  iban            String
  jazzCashNumber  String
  jazzCashTitle   String   @default("")
  easyPaisaNumber String
  easyPaisaTitle  String   @default("")
  instructions    String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("payment_settings")
}

model Donation {
  id                 String         @id @default(cuid())

  type               DonationType

  donorName          String?
  email              String?
  description        String?

  amount             Decimal
  currency           String         @default("PKR")

  screenshotUrl      String
  screenshotPublicId String

  status             DonationStatus @default(PENDING)

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("donations")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscribers")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}

model Testimonial {
  id          String            @id @default(cuid())
  name        String
  gender      Gender
  country     String
  rating      Int
  description String
  status      TestimonialStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("testimonials")
}

enum Gender {
  MALE
  FEMALE
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Role {
  ADMIN
  USER
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum Region {
  PAKISTAN
  AUSTRALIA
  CANADA
  EUROPE
  KSA
  KUWAIT
  QATAR
  UAE
  UK
  US
  OTHERS
}

enum PackageTier {
  BASIC
  INTENSIVE
  PREMIUM
  CUSTOM
  NONE
}

enum EnrollmentType {
  REGULAR
  FREE_TRIAL
}

enum PaymentMethod {
  BANK_TRANSFER
  JAZZCASH
  EASYPAISA
}

enum PaymentStatus {
  UNDER_REVIEW
  PAID
  REJECTED
}

enum DonationType {
  LILLAH
  SADAQAH_JARIYAH
  SADAQAH_NAFILLAH
  ZAKAT
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
}

enum EnrollmentMode {
  ONE_ON_ONE
  GROUP
}

model Country {
  id             String           @id @default(cuid())
  name           String
  code           String           @unique
  currency       String
  supportedModes EnrollmentMode[]

  @@map("countries")
}
